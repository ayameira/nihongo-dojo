# Nihongo Dojo Backend Configuration

# Database (SQLite by default, can be changed to PostgreSQL)
DATABASE_URL=sqlite+aiosqlite:///./nihongo_dojo.db
# For PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/nihongo_dojo

# LLM Provider
#
# Default: Gemini, using the existing GEMINI_* settings below.
# Free quick trial with Groq:
#   LLM_PROVIDER=groq
#   LLM_API_KEY=your_groq_api_key_here
#   LLM_MODEL=llama-3.1-8b-instant
LLM_PROVIDER=gemini
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Optional: set these to switch providers from the in-app model selector.
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Gemini API (backwards-compatible default provider)
GEMINI_API_KEY=your_gemini_api_key_here
# Available models: gemini-3-flash-preview, gemini-3-pro-preview
GEMINI_MODEL=gemini-3-flash-preview

# Paths
CLASS_NOTES_PATH=../CLASS_NOTES.md
ANKI_COLLECTION_PATH=~/Library/Application Support/Anki2/User 1/collection.anki2

# Cost Tracking
COST_LIMIT_WEEKLY=10.0
# Pricing is auto-set from model. Override here if needed:
# GEMINI_INPUT_COST_PER_1M=0.50
# GEMINI_OUTPUT_COST_PER_1M=3.00
# LLM_INPUT_COST_PER_1M=0.0
# LLM_OUTPUT_COST_PER_1M=0.0

# Notes
NOTES_TOKEN_LIMIT=1000
